# Wenando API — Hostinger Cloud production template
# Copy: cp .env.production.example .env
# Then fill DB_* and MAIL_* ; run: php artisan key:generate

APP_NAME=Wenando
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.wenando.com

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Hostinger MySQL — credentials from hPanel → Databases
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wenando
DB_USERNAME=
DB_PASSWORD=

# Sanctum SPA (wenando.com ↔ api.wenando.com)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.wenando.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# No Redis on Hostinger shared — database queue + cron worker
QUEUE_CONNECTION=database
CACHE_STORE=file

# Hostinger Email — create mailbox in hPanel; set password only in .env (never commit)
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SCHEME=smtps
# Alternative STARTTLS if 465 blocked: MAIL_PORT=587 MAIL_SCHEME=smtp
MAIL_USERNAME=hola@wenando.com
MAIL_PASSWORD=
MAIL_TIMEOUT=30
MAIL_EHLO_DOMAIN=wenando.com
MAIL_FROM_ADDRESS=hola@wenando.com
MAIL_FROM_NAME="Wenando"
MAIL_REPLY_TO_ADDRESS=hola@wenando.com

SANCTUM_STATEFUL_DOMAINS=wenando.com,www.wenando.com
FRONTEND_URL=https://wenando.com

WENANDO_PRIVACY_POLICY_VERSION=1.0.0
WENANDO_PRIVACY_CONTACT_EMAIL=hola@wenando.com
# WENANDO_PRIVACY_EXPORT_NOTIFY=true

# Payment webhooks (required for wallet recharge in production)
WENANDO_WEBHOOK_SECRET=
WENANDO_BANK_IBAN=
WENANDO_BANK_BENEFICIARY=
# WENANDO_WALLET_INSTANT_RECHARGE=false

# Stripe (wallet card recharge)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# OTP captcha (recommended in production — pairs with VITE_HCAPTCHA_SITE_KEY on SPA build)
HCAPTCHA_SECRET=
# RECAPTCHA_SECRET=
# Optional — leave empty to disable Sentry; set DSN from Sentry project settings
SENTRY_LARAVEL_DSN=
# SENTRY_SAMPLE_RATE=0.2
# SENTRY_TRACES_SAMPLE_RATE=0.1
