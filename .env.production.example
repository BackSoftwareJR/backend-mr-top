# Wenando API — Hostinger Cloud production template
# Copy: cp .env.production.example .env
# Then fill DB_* and MAIL_* ; run: php artisan key:generate

APP_NAME=Wenando
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.wenando.com

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# Hostinger MySQL — credentials from hPanel → Databases
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wenando
DB_USERNAME=
DB_PASSWORD=

# Sanctum SPA (wenando.com ↔ api.wenando.com)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.wenando.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# No Redis on Hostinger shared — database queue + cron worker
QUEUE_CONNECTION=database
CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@wenando.com
MAIL_FROM_NAME="${APP_NAME}"

SANCTUM_STATEFUL_DOMAINS=wenando.com,www.wenando.com
FRONTEND_URL=https://wenando.com

WENANDO_PRIVACY_POLICY_VERSION=1.0.0

# Optional production integrations (leave empty until configured)
HCAPTCHA_SECRET=
SENTRY_LARAVEL_DSN=
