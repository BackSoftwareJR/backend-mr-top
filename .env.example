APP_NAME=Wenando
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.wenando.com

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wenando
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.wenando.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

# Hostinger SMTP (Laravel 13: MAIL_SCHEME; legacy MAIL_ENCRYPTION still mapped in config/mail.php)
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_SCHEME=smtps
# Legacy alias (optional): MAIL_ENCRYPTION=ssl  → same as MAIL_SCHEME=smtps
# Alternative STARTTLS: MAIL_PORT=587 MAIL_SCHEME=smtp
MAIL_USERNAME=hola@wenando.com
MAIL_PASSWORD=
MAIL_TIMEOUT=30
MAIL_EHLO_DOMAIN=wenando.com
MAIL_FROM_ADDRESS=hola@wenando.com
MAIL_FROM_NAME="Wenando"
MAIL_REPLY_TO_ADDRESS=hola@wenando.com

SANCTUM_STATEFUL_DOMAINS=wenando.com,www.wenando.com
FRONTEND_URL=https://wenando.com

# Legal consent version (must match SPA footer / consent_logs.policy_version)
WENANDO_PRIVACY_POLICY_VERSION=1.0.0

# Production bot protection (optional in dev)
HCAPTCHA_SECRET=

# Error tracking (optional)
SENTRY_LARAVEL_DSN=

VITE_APP_NAME="${APP_NAME}"
